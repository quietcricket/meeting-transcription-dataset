		intervals [1]:
			xmin = 9.14
			xmax = 21.8
			text = "好，那就由我来先分析一下餐饮行业的现状，嗯随着我国国民经济的快速发展，居民的收入水平越来越高，餐饮消费需求日益旺盛。"
		intervals [2]:
			xmin = 22.23
			xmax = 25.73
			text = "餐饮营业额一直保持着较强的增长势头。"
		intervals [3]:
			xmin = 32.65
			xmax = 41.02
			text = "对，然后呢也有数据统计，说近五年来我国餐饮业每年都以百分之十八左右的速度增增长。"
		intervals [4]:
			xmin = 41.43
			xmax = 47.92
			text = "是GDP发展速度的两倍，可以说整个餐饮市场发展态势良好。"
		intervals [5]:
			xmin = 54.26
			xmax = 56.11
			text = "对对前景。"
		intervals [6]:
			xmin = 58.43
			xmax = 67.16
			text = "嗯，然后主要体现在连锁经营，品牌培育，技术创新管理科学化为代表的现代餐饮企业。"
		intervals [7]:
			xmin = 67.78
			xmax = 80.69
			text = "逐步替代了传统餐饮业的手工随意性生产，单店作坊式，人为经验管理型，快步向企业化集团化连连锁化和现代化迈进。"
		intervals [8]:
			xmin = 91.83
			xmax = 92.31
			text = "对。"
		intervals [9]:
			xmin = 93.95
			xmax = 94.37
			text = "然后。"
		intervals [10]:
			xmin = 97.42
			xmax = 104.51
			text = "对的，然后呢，让餐饮业引入电子商务也是势在必行餐饮业的发展态势。"
		intervals [11]:
			xmin = 106.61
			xmax = 114.42
			text = "然后因为这样子把两者联合起来，就可能会提高餐饮业的发展，他前景就会越来越好。"
		intervals [12]:
			xmin = 116.17
			xmax = 121.71
			text = "呃然后餐饮企业的连锁化集团化是我国餐饮业发展的主流。"
		intervals [13]:
			xmin = 123.52
			xmax = 133.89
			text = "大众消费也成为餐饮消费的主要力量，餐饮文化成为餐饮竞争的分水岭，品牌成为餐饮企业的核心竞争力。"
		intervals [14]:
			xmin = 144.9
			xmax = 151.21
			text = "对，然后我们科学化，营养化也成为餐饮业的重要指向标。"
		intervals [15]:
			xmin = 153.12
			xmax = 156.07
			text = "对，就我们餐饮就得科学化，营养化嘛。"
		intervals [16]:
			xmin = 159.28
			xmax = 160.7
			text = "对标准化。"
		intervals [17]:
			xmin = 162.13
			xmax = 176.65
			text = "然后餐饮业属于第三产业，随着一个国家的经济发展，社会进步，现代化程度的不断提高，由此可见餐饮业的发展潜力巨大，设施设备将不断现代化。"
		intervals [18]:
			xmin = 177.05
			xmax = 180.06
			text = "经营管理也将日益科学化、专业化。"
		intervals [19]:
			xmin = 183.57
			xmax = 191.12
			text = "自从我国实行改革开放政策以来，我国的经济就得以迅速发展，餐饮业也随之蓬勃兴旺。"
		intervals [20]:
			xmin = 192.14
			xmax = 199.26
			text = "特别是我国加入了世贸贸世界贸易组织之后，然后我国餐饮业面对营销。"
		intervals [21]:
			xmin = 201.27
			xmax = 202.61
			text = "营销政策。"
		intervals [22]:
			xmin = 204.36
			xmax = 211.82
			text = "营销国际竞争，同时又为我国餐饮业的发展创造了前所未有的良好机遇。"
		intervals [23]:
			xmin = 220.02
			xmax = 220.32
			text = "对。"
		intervals [24]:
			xmin = 223.91
			xmax = 224.29
			text = "好。"
		intervals [25]:
			xmin = 249.5
			xmax = 255.08
